# Env example (no secrets)
# Copy to .env.local when needed. App runs with all vars unset (safe defaults).

# ——— Environment profile ———
# VERAZ_ENV=development
# Values: development | staging | production

# ——— App ———
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_NAME=Veraz

# ——— Supabase (content persistence) ———
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ——— AI Engine (optional; default = disabled) ———
# AI_MODE=disabled
# AI_PROVIDER=none
# AI_FAIL_OPEN=true

# Provider credentials — only when AI_MODE != disabled:
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_BASE_URL=

# ——— News Ingestion ———
# NEWS_INGESTION_ENABLED=true
# Add or remove sources by editing the JSON array (one object per RSS feed).
# Full catalog documented in docs/news-sources.md — copy from src/config/domains/rss-feed-catalog.ts
# NEWS_RSS_FEEDS=[{"sourceSlug":"cnbc-top","feedUrl":"https://search.cnbc.com/rs/search/combinedcms/view.xml?partnerId=wrss01&id=10000664","defaultLanguageCode":"en","defaultTopicGroup":"economia","primaryVertical":"finance"},{"sourceSlug":"marketwatch","feedUrl":"https://www.marketwatch.com/rss/topstories","defaultLanguageCode":"en","defaultTopicGroup":"economia","primaryVertical":"finance"},{"sourceSlug":"bloomberg-linea","feedUrl":"https://www.bloomberglinea.com/arc/outboundfeeds/rss/?outputType=xml","defaultLanguageCode":"es","defaultTopicGroup":"economia","primaryVertical":"finance"},{"sourceSlug":"expansion","feedUrl":"https://www.expansion.com/rss/portada.xml","defaultLanguageCode":"es","defaultTopicGroup":"economia","primaryVertical":"finance"},{"sourceSlug":"el-pais-economia","feedUrl":"https://feeds.elpais.com/mrss-s/pages/ep/site/elpais.com/section/economia/portada","defaultLanguageCode":"es","defaultTopicGroup":"economia","primaryVertical":"finance"},{"sourceSlug":"techcrunch","feedUrl":"https://techcrunch.com/feed/","defaultLanguageCode":"en","defaultTopicGroup":"tecnologia","primaryVertical":"tech"},{"sourceSlug":"the-verge","feedUrl":"https://www.theverge.com/rss/index.xml","defaultLanguageCode":"en","defaultTopicGroup":"tecnologia","primaryVertical":"tech"},{"sourceSlug":"ars-technica","feedUrl":"https://feeds.arstechnica.com/arstechnica/index","defaultLanguageCode":"en","defaultTopicGroup":"tecnologia","primaryVertical":"tech"},{"sourceSlug":"wired","feedUrl":"https://www.wired.com/feed/rss","defaultLanguageCode":"en","defaultTopicGroup":"tecnologia","primaryVertical":"tech"},{"sourceSlug":"mit-tech-review","feedUrl":"https://www.technologyreview.com/feed/","defaultLanguageCode":"en","defaultTopicGroup":"tecnologia","primaryVertical":"tech"},{"sourceSlug":"engadget","feedUrl":"https://www.engadget.com/rss.xml","defaultLanguageCode":"en","defaultTopicGroup":"tecnologia","primaryVertical":"tech"},{"sourceSlug":"el-pais-tecnologia","feedUrl":"https://feeds.elpais.com/mrss-s/pages/ep/site/elpais.com/section/tecnologia/portada","defaultLanguageCode":"es","defaultTopicGroup":"tecnologia","primaryVertical":"tech"},{"sourceSlug":"bbc-mundo","feedUrl":"https://feeds.bbci.co.uk/mundo/rss.xml","defaultLanguageCode":"es","primaryVertical":"general"},{"sourceSlug":"el-pais","feedUrl":"https://feeds.elpais.com/mrss-s/pages/ep/site/elpais.com/portada","defaultLanguageCode":"es","primaryVertical":"general"},{"sourceSlug":"infobae","feedUrl":"https://www.infobae.com/arc/outboundfeeds/rss/?outputType=xml","defaultLanguageCode":"es","primaryVertical":"general"},{"sourceSlug":"la-nacion","feedUrl":"https://www.lanacion.com.ar/arc/outboundfeeds/rss/?outputType=xml","defaultLanguageCode":"es","primaryVertical":"general"}]
# Local auto-ingest loop interval (seconds). Used by `npm run ingest:watch`.
# NEWS_INGESTION_INTERVAL_SECONDS=900
# NEWS_DISCOVER_INTERVAL_SECONDS=900
# NEWS_HEALTH_CHECK_INTERVAL_SECONDS=300

# ——— Feature flags (default = off / safe) ———
# FF_AI=false
# FF_PREMIUM=false
# FF_NEWS_COMPARISON=false
# FF_TIMELINE=true
# FF_ADVANCED_SEARCH=false
# FF_NOTIFICATIONS=false
# FF_MAINTENANCE_MODE=false

# ——— Cache (future) ———
# CACHE_DEFAULT_TTL_SECONDS=60

# ——— Security (cron / internal jobs) ———
# Required in production for /api/cron/ingest/* endpoints.
# CRON_SECRET=
# After filling .env.local, sync to Vercel: ./scripts/sync-vercel-env.sh

# Do not commit .env.local or real secrets.
